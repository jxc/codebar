# CodeBar release signing secrets
# Copy to .env and fill in values, then run: make set-secrets

# Path to exported .p12 certificate file (will be base64-encoded automatically)
APPLE_CERTIFICATE_P12_PATH=~/Documents/Certificates.p12

# Password used when exporting the .p12
APPLE_CERTIFICATE_PASSWORD=

# Apple ID email for notarization
APPLE_DEVELOPER_ID=

# App-specific password (generate at https://appleid.apple.com/account/manage)
APPLE_APP_SPECIFIC_PASSWORD=

# Apple Developer Team ID
APPLE_TEAM_ID=PUHY9G5JNJ
